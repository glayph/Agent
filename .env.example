# Hiro local environment template.
# Copy values into .env on your own machine; never commit real tokens.

OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
TELEGRAM_BOT_TOKEN=
WHATSAPP_BRIDGE_URL=
WHATSAPP_WEBHOOK_TOKEN=
# Missing provider keys are normal until each user adds their own credentials.
Hiro_WARN_MISSING_API_KEYS=false

CORE_HOST=127.0.0.1
CORE_PORT=8000
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18800
# Use Hiro_ALLOWED_ORIGINS=* only for trusted local/dev networks.
Hiro_ALLOWED_ORIGINS=http://localhost:18800,http://127.0.0.1:18800
DEFAULT_MODEL=google/gemini-2.0-flash-001
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096
MAX_CONCURRENT_TASKS=3
MAX_PARALLEL_TOOL_CALLS=3
TOOL_LOCK_TIMEOUT_MS=30000
LITELLM_BASE_URL=http://127.0.0.1:4000/v1
LITELLM_CONFIG_PATH=config/litellm.yaml
# Optional. Auto-generated in workspace/data if omitted.
LITELLM_MASTER_KEY=
# API key auth protects non-dashboard APIs and WebSocket clients. Set a unique
# 16+ character secret before starting with ENABLE_API_KEY_AUTH=true.
ENABLE_API_KEY_AUTH=false
API_KEY_SECRET=
# MCP exposes tool execution and is disabled until explicitly enabled with a
# strong API_KEY_SECRET.
ENABLE_MCP=false
Hiro_LAUNCHER_BOOTSTRAP_TOKEN=
# Default keeps Drive/File Manager write, rename, delete, run, upload, copy-target,
# and move operations inside the workspace. Set true only for trusted local use.
Hiro_FILE_MANAGER_ALLOW_SYSTEM_WRITE=false
ENABLE_TELEGRAM=false
ENABLE_WHATSAPP=true
