    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.7.0",
    
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
